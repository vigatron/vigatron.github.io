000000cc <EL2008GUI_GetTextHeight>:

auint16 EL2008GUI_GetTextWidth( const char *pText, uchar8 ucFont )
{
 uint16 uiResult=0;
 uchar8 ucLen = strlen( pText );
 
 uchar8 i;
 for( i=0;i<ucLen;i++ )
 {
     uchar8 ucW = FONT_GET_SYM_W( pText[i], ucFont );
     if( pText[i] == ' ' ) ucW = SYMMINWIDTH;
     uiResult += ucW + 1;
 }
 
 return uiResult;
}

